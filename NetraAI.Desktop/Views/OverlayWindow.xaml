<Window x:Class="NetraAI.Desktop.Views.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Netra AI"
    Height="500"
    Width="400"
    WindowStyle="None"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    ShowInTaskbar="False"
    ResizeMode="CanResizeWithGrip">
    
    <Border Background="{StaticResource BrushSurface}" CornerRadius="14" 
            BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" 
            Effect="{StaticResource ResourceKey=ShadowEffect}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>
            
            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#101010" CornerRadius="14,14,0,0" Padding="14,10" BorderBrush="{StaticResource BrushDivider}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="Netra AI Assistant" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                    <Button Content="Close" HorizontalAlignment="Right" Style="{StaticResource SecondaryButtonStyle}" Padding="10,4"/>
                </Grid>
            </Border>
            
            <!-- Chat Area -->
            <ScrollViewer Grid.Row="1" Padding="18">
                <TextBlock Text="Overlay is ready. Captured context and AI responses will appear here." 
                           Foreground="{StaticResource BrushMuted}" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
            </ScrollViewer>
            
            <!-- Input Area -->
            <Border Grid.Row="2" Background="#101010" CornerRadius="0,0,14,14" Padding="12" BorderBrush="{StaticResource BrushDivider}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox Grid.Column="0" Style="{StaticResource CustomTextBoxStyle}" Padding="12,8" Height="40" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Send" Style="{StaticResource PrimaryButtonStyle}" Margin="10,0,0,0" Padding="16,8" Height="40" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
    <!-- Shadow Effect Definition -->
    <Window.Resources>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="18" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
    </Window.Resources>
</Window>
