<UserControl x:Class="NetraAI.Desktop.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrushBackground}"
    Foreground="{StaticResource BrushText}"
    Loaded="Window_Loaded">

    <UserControl.Resources>
        <SolidColorBrush x:Key="BrushBackground" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="BrushSurface" Color="#141414"/>
        <SolidColorBrush x:Key="BrushPrimary" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="BrushText" Color="#F4F4F4"/>
        <SolidColorBrush x:Key="BrushMuted" Color="#9D9D9D"/>
        <SolidColorBrush x:Key="BrushDivider" Color="#2A2A2A"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushBackground}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="12" Padding="16,12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="14,11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1B1B1B"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#202020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>

        <Style x:Key="CustomTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#101010"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#5A5A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BrushBackground}">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="LeftPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.45"/>
                        <DoubleAnimation Storyboard.TargetName="RightPanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
                        <DoubleAnimation Storyboard.TargetName="LeftPanelShift" Storyboard.TargetProperty="X" From="-20" To="0" Duration="0:0:0.45"/>
                        <DoubleAnimation Storyboard.TargetName="RightPanelShift" Storyboard.TargetProperty="X" From="22" To="0" Duration="0:0:0.5"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Grid MaxWidth="1120" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="52">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="LeftPanel" Grid.Column="0" VerticalAlignment="Center" Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="LeftPanelShift"/>
                </StackPanel.RenderTransform>

                <TextBlock Text="Netra AI" FontSize="62" FontWeight="Bold" Foreground="{StaticResource BrushText}" Margin="0,0,0,20"/>
                <TextBlock Text="A focused workspace for conversations, permissions, and AI-assisted workflows." TextWrapping="Wrap" Foreground="{StaticResource BrushMuted}" FontSize="18" LineHeight="28" MaxWidth="500" Margin="0,0,0,40"/>

                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource BrushPrimary}" Margin="0,6,14,0"/>
                        <TextBlock Text="Unified onboarding in one continuous interface" Foreground="{StaticResource BrushText}" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                        <Border Width="10" Height="10" CornerRadius="5" Background="#8F8F8F" Margin="0,6,14,0"/>
                        <TextBlock Text="Secure authentication with clean, distraction-free UI" Foreground="{StaticResource BrushText}" FontSize="15"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border Width="10" Height="10" CornerRadius="5" Background="#6F6F6F" Margin="0,6,14,0"/>
                        <TextBlock Text="Minimal, professional layout with refined typography" Foreground="{StaticResource BrushText}" FontSize="15"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border x:Name="RightPanel" Grid.Column="1" Background="{StaticResource BrushSurface}" CornerRadius="18" Padding="42" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="RightPanelShift"/>
                </Border.RenderTransform>

                <StackPanel x:Name="LoginPanel">
                    <TextBlock Text="Sign in" FontSize="42" FontWeight="Bold" Foreground="{StaticResource BrushText}" Margin="0,0,0,6"/>
                    <TextBlock Text="Continue to your workspace" FontSize="15" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,30"/>

                    <Border x:Name="ErrorBorder" Background="#2A1515" BorderBrush="#5A2F2F" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,18" Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage" Foreground="#F2DADA" TextWrapping="Wrap" FontSize="12"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                        <Button x:Name="SignInTab" Content="Sign In" Style="{StaticResource TabButtonStyle}" Background="{StaticResource BrushPrimary}" Foreground="{StaticResource BrushBackground}" BorderBrush="{StaticResource BrushPrimary}" Click="SignInTab_Click" Tag="signin"/>
                        <Button x:Name="SignUpTab" Content="Sign Up" Style="{StaticResource TabButtonStyle}" Margin="10,0,0,0" Background="Transparent" Foreground="{StaticResource BrushText}" BorderBrush="{StaticResource BrushDivider}" Click="SignUpTab_Click" Tag="signup"/>
                    </StackPanel>

                    <TextBlock Text="Email" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="EmailTextBox" Style="{StaticResource CustomTextBoxStyle}" Margin="0,0,0,16" Height="42"/>

                    <TextBlock Text="Password" Foreground="{StaticResource BrushText}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" Height="42" Background="#101010" Foreground="{StaticResource BrushText}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" Padding="14,10" FontSize="15"/>

                    <StackPanel x:Name="DisplayNamePanel" Visibility="Collapsed" Margin="0,10,0,16">
                        <TextBlock Text="Display Name" Foreground="{StaticResource BrushText}" Margin="0,0,0,8" FontSize="13" FontWeight="SemiBold"/>
                        <TextBox x:Name="DisplayNameTextBox" Style="{StaticResource CustomTextBoxStyle}" Height="42"/>
                    </StackPanel>

                    <CheckBox x:Name="RememberMeCheckbox" Content="Remember me" Foreground="{StaticResource BrushMuted}" Margin="0,0,0,22"/>

                    <Button x:Name="AuthButton" Content="Sign In" Style="{StaticResource PrimaryButtonStyle}" Height="48" Margin="0,0,0,12" Click="AuthButton_Click"/>

                    <StackPanel x:Name="LoadingPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,10" Visibility="Collapsed">
                        <TextBlock Text="Authenticating..." Foreground="{StaticResource BrushMuted}" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button x:Name="GoogleButton" Content="Sign in with Google" Style="{StaticResource SecondaryButtonStyle}" Height="46" Click="GoogleButton_Click" IsEnabled="True"/>
                    <TextBlock x:Name="GoogleConfigText" Text="Google Sign-In not configured" Foreground="{StaticResource BrushMuted}" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" Visibility="Collapsed"/>

                    <Border Height="1" Background="{StaticResource BrushDivider}" Margin="0,22,0,16"/>

                    <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource BrushMuted}" x:Name="ToggleAuthLink">
                        <Run Text="Don't have an account? " x:Name="ToggleAuthText"/>
                        <Hyperlink Foreground="{StaticResource BrushText}" TextDecorations="None" Click="ToggleAuth_Click">Sign up</Hyperlink>
                    </TextBlock>

                    <TextBlock x:Name="ForgotPasswordLink" Margin="0,8,0,0" HorizontalAlignment="Center" Visibility="Visible">
                        <Hyperlink Foreground="{StaticResource BrushMuted}" TextDecorations="None" Click="ForgotPassword_Click">Forgot password?</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
