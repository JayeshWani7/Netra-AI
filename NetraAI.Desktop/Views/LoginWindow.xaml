<Window x:Class="NetraAI.Desktop.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Netra AI - Login"
    Height="600"
    Width="450"
    WindowStartupLocation="CenterScreen"
    Background="{StaticResource BrushBackground}"
    Foreground="{StaticResource BrushText}"
    ResizeMode="NoResize">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="40">
            <TextBlock Text="Netra AI" Style="{StaticResource HeaderTextStyle}" TextAlignment="Center"/>
            <TextBlock Text="Sign in to continue" Style="{StaticResource SubHeaderTextStyle}" TextAlignment="Center" Margin="0,0,0,32"/>
            
            <!-- Email Input -->
            <TextBlock Text="Email" Foreground="{StaticResource BrushText}" Margin="0,0,0,8"/>
            <TextBox x:Name="EmailTextBox" Style="{StaticResource CustomTextBoxStyle}" Margin="0,0,0,16" Height="40"/>
            
            <!-- Password Input -->
            <TextBlock Text="Password" Foreground="{StaticResource BrushText}" Margin="0,0,0,8"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8" Height="40" Background="{StaticResource BrushSurface}" Foreground="{StaticResource BrushText}" BorderBrush="#444444" BorderThickness="1" Padding="12,10" FontSize="14"/>
            
            <!-- Remember Me -->
            <CheckBox Content="Remember me" Foreground="{StaticResource BrushText}" Margin="0,0,0,24"/>
            
            <!-- Login Button -->
            <Button Content="Sign In" Style="{StaticResource PrimaryButtonStyle}" Height="44" Margin="0,0,0,12"/>
            
            <!-- Google Login -->
            <Button Content="Sign in with Google" Height="44" Background="#333333" Foreground="{StaticResource BrushText}" Margin="0,0,0,12"/>
            
            <!-- Links -->
            <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="{StaticResource BrushText}">
                <Run Text="Don't have an account? "/>
                <Hyperlink Foreground="{StaticResource BrushPrimary}" TextDecorations="None">Sign up</Hyperlink>
            </TextBlock>
            
            <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center">
                <Hyperlink Foreground="{StaticResource BrushPrimary}" TextDecorations="">Forgot password?</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
