<UserControl x:Class="NetraAI.Desktop.Views.PermissionsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrushBackground}"
    Foreground="{StaticResource BrushText}"
    Loaded="Window_Loaded">

    <Grid Margin="56">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="PagePanel" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35"/>
                        <DoubleAnimation Storyboard.TargetName="PageShift" Storyboard.TargetProperty="Y" From="16" To="0" Duration="0:0:0.35"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>

        <Border x:Name="PagePanel" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="18" Padding="36" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PageShift"/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                    <TextBlock Text="Permissions" FontSize="40" FontWeight="Bold" Margin="0,0,0,8"/>
                    <TextBlock Text="Review what Netra AI can access. You can change these settings later." Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,28"/>

                    <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◻" FontSize="16" Margin="0,2,14,0" Foreground="{StaticResource BrushText}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Screen Capture" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Required to understand on-screen context and provide accurate assistance." Style="{StaticResource SubHeaderTextStyle}" Margin="0,4,0,0" FontSize="13"/>
                            </StackPanel>
                            <CheckBox x:Name="ScreenCaptureCheckbox" Grid.Column="2" VerticalAlignment="Center" IsChecked="True" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◻" FontSize="16" Margin="0,2,14,0" Foreground="{StaticResource BrushText}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Microphone" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Optional voice input for hands-free prompts and commands." Style="{StaticResource SubHeaderTextStyle}" Margin="0,4,0,0" FontSize="13"/>
                            </StackPanel>
                            <CheckBox x:Name="MicrophoneCheckbox" Grid.Column="2" VerticalAlignment="Center" IsChecked="False" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◻" FontSize="16" Margin="0,2,14,0" Foreground="{StaticResource BrushText}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Background Execution" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Keeps Netra AI available while you continue using other applications." Style="{StaticResource SubHeaderTextStyle}" Margin="0,4,0,0" FontSize="13"/>
                            </StackPanel>
                            <CheckBox x:Name="BackgroundCheckbox" Grid.Column="2" VerticalAlignment="Center" IsChecked="True" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>

                    <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="◻" FontSize="16" Margin="0,2,14,0" Foreground="{StaticResource BrushText}"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Clipboard Access" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Optional copy and paste support for faster sharing and output handling." Style="{StaticResource SubHeaderTextStyle}" Margin="0,4,0,0" FontSize="13"/>
                            </StackPanel>
                            <CheckBox x:Name="ClipboardCheckbox" Grid.Column="2" VerticalAlignment="Center" IsChecked="False" Margin="12,0,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,32,0,0">
                    <Button x:Name="DenyAllButton" Content="Deny All" Style="{StaticResource SecondaryButtonStyle}" Height="44" Width="128" Margin="0,0,12,0" Click="DenyAllButton_Click"/>
                    <Button x:Name="ContinueButton" Content="Save &amp; Continue" Style="{StaticResource PrimaryButtonStyle}" Height="44" Width="168" Click="ContinueButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
