<UserControl x:Class="NetraAI.Desktop.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrushBackground}"
    Foreground="{StaticResource BrushText}"
    Loaded="Window_Loaded">

    <UserControl.Resources>
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ToggleButton x:Name="ToggleButton" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" Focusable="False" Background="Transparent" BorderThickness="0">
                                <Grid Margin="10,4">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,18,0" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                    <Path Fill="#000000" Data="M 0 0 L 6 6 L 12 0 Z" Width="12" Height="6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border CornerRadius="8" Background="#FFFFFF" BorderBrush="#D0D0D0" BorderThickness="1" Margin="0,6,0,0">
                                    <ScrollViewer CanContentScroll="True" MaxHeight="200" Padding="4">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="0,0,14,0"/>
                    <TextBlock Text="Preferences and permissions" Style="{StaticResource SubHeaderTextStyle}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BackButton" Content="Back" Style="{StaticResource SecondaryButtonStyle}" Click="BackButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Appearance" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="Theme" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <ComboBox x:Name="ThemeComboBox" Height="42" Style="{StaticResource SettingsComboBoxStyle}">
                            <ComboBoxItem Content="Dark" Style="{StaticResource SettingsComboBoxItemStyle}"/>
                            <ComboBoxItem Content="Light" Style="{StaticResource SettingsComboBoxItemStyle}"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Hotkeys" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="Primary hotkey" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,0,0,6"/>
                        <TextBox x:Name="HotkeyTextBox" Style="{StaticResource CustomTextBoxStyle}" Height="42"/>
                        <TextBlock Text="Use format like Ctrl+Alt+A" Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Startup" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <CheckBox x:Name="AutoStartCheckbox" Content="Launch Netra AI on login" FontSize="14" Foreground="{StaticResource BrushText}" Margin="0,0,0,6"/>
                        <TextBlock Text="Keeps Netra AI ready in the background." Foreground="{StaticResource BrushMuted}" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="26" Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="Permissions" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                        <CheckBox x:Name="ScreenAccessCheckbox" Content="Screen capture (required)" FontSize="14" Foreground="{StaticResource BrushText}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="MicrophoneAccessCheckbox" Content="Microphone" FontSize="14" Foreground="{StaticResource BrushText}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="BackgroundAccessCheckbox" Content="Background execution" FontSize="14" Foreground="{StaticResource BrushText}" Margin="0,0,0,6"/>
                        <CheckBox x:Name="ClipboardAccessCheckbox" Content="Clipboard access" FontSize="14" Foreground="{StaticResource BrushText}"/>
                        <TextBlock Text="These are saved per device and can be updated anytime." Foreground="{StaticResource BrushMuted}" FontSize="12" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="26">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="SaveButton" Content="Save" Style="{StaticResource PrimaryButtonStyle}" Height="42" Width="120" Click="SaveButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
