<UserControl x:Class="NetraAI.Desktop.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BrushBackground}"
    Foreground="{StaticResource BrushText}"
    Loaded="Window_Loaded">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Netra AI" FontSize="22" FontWeight="Bold" Margin="0,0,14,0"/>
                    <TextBlock Text="Workspace" Style="{StaticResource SubHeaderTextStyle}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" Foreground="{StaticResource BrushMuted}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button x:Name="SettingsButton" Content="Settings" Style="{StaticResource SecondaryButtonStyle}" Click="SettingsButton_Click" Margin="0,0,8,0"/>
                    <Button x:Name="LogoutButton" Content="Logout" Style="{StaticResource SecondaryButtonStyle}" Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="20">
                <StackPanel>
                    <TextBlock Text="Quick Actions" FontSize="21" FontWeight="Bold" Margin="0,0,0,14"/>

                    <Button x:Name="CaptureButton" Content="Start Netra" Style="{StaticResource PrimaryButtonStyle}" Height="42" Margin="0,0,0,18" Click="CaptureButton_Click"/>

                    <Border Height="1" Background="{StaticResource BrushDivider}" Margin="0,0,0,16"/>

                    <TextBlock Text="Chat History" FontSize="21" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ListBox x:Name="ChatHistoryList" Background="Transparent" Foreground="{StaticResource BrushText}" BorderThickness="0" SelectionChanged="ChatHistoryList_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                        <ListBoxItem Content="No chat history yet" Foreground="{StaticResource BrushMuted}" IsEnabled="False"/>
                    </ListBox>

                    <Border Height="1" Background="{StaticResource BrushDivider}" Margin="0,16,0,16"/>

                    <TextBlock Text="Statistics" FontSize="21" FontWeight="Bold" Margin="0,0,0,12"/>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="Captures Today" Foreground="{StaticResource BrushMuted}" FontSize="12"/>
                        <TextBlock x:Name="CaptureCountText" Text="0" Foreground="{StaticResource BrushText}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Questions Asked" Foreground="{StaticResource BrushMuted}" FontSize="12"/>
                        <TextBlock x:Name="QuestionCountText" Text="0" Foreground="{StaticResource BrushText}" FontSize="28" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="18,0,0,0" Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="14" Padding="34">
                <Grid>
                    <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center">
                        <TextBlock Text="Welcome back" FontSize="46" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="WelcomeText" Text="" Style="{StaticResource SubHeaderTextStyle}" Margin="0,0,0,26"/>

                        <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="22" Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="Getting Started" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
                                <TextBlock Text="1. Use Ctrl+Alt+S to capture your screen." Foreground="{StaticResource BrushText}" Margin="0,0,0,8" FontSize="15"/>
                                <TextBlock Text="2. OCR extracts visible text from the capture." Foreground="{StaticResource BrushText}" Margin="0,0,0,8" FontSize="15"/>
                                <TextBlock Text="3. Ask Netra AI for context and next actions." Foreground="{StaticResource BrushText}" FontSize="15"/>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="StatusText" Text="Ready to capture. Use keyboard shortcut or the action button." Foreground="{StaticResource BrushMuted}" FontStyle="Italic" FontSize="14"/>
                    </StackPanel>

                    <StackPanel x:Name="ChatDetailPanel" Visibility="Collapsed">
                        <TextBlock Text="Chat Detail" FontSize="34" FontWeight="Bold" Margin="0,0,0,16"/>

                        <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="22" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Question" Foreground="{StaticResource BrushMuted}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock x:Name="ChatDetailQuestion" TextWrapping="Wrap" FontSize="16"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#101010" BorderBrush="{StaticResource BrushDivider}" BorderThickness="1" CornerRadius="12" Padding="22">
                            <StackPanel>
                                <TextBlock Text="Answer" Foreground="{StaticResource BrushMuted}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="320">
                                    <TextBlock x:Name="ChatDetailAnswer" TextWrapping="Wrap" FontSize="15" Padding="0,5,0,5"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
