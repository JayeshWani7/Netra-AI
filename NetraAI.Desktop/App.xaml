<Application x:Class="NetraAI.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NetraAI.Desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Color Palette (Dark Theme) -->
            <Color x:Key="ColorBackground">#1a1a1a</Color>
            <Color x:Key="ColorSurface">#2d2d2d</Color>
            <Color x:Key="ColorPrimary">#7c3aed</Color>
            <Color x:Key="ColorText">#f0f0f0</Color>
            <Color x:Key="ColorError">#ef4444</Color>
            
            <SolidColorBrush x:Key="BrushBackground" Color="#1a1a1a"/>
            <SolidColorBrush x:Key="BrushSurface" Color="#2d2d2d"/>
            <SolidColorBrush x:Key="BrushPrimary" Color="#7c3aed"/>
            <SolidColorBrush x:Key="BrushText" Color="#f0f0f0"/>
            <SolidColorBrush x:Key="BrushError" Color="#ef4444"/>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
