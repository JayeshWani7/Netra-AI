<Application x:Class="NetraAI.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NetraAI.Desktop">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Monochrome Theme Palette -->
            <Color x:Key="ColorBackground">#0A0A0A</Color>
            <Color x:Key="ColorSurface">#141414</Color>
            <Color x:Key="ColorPrimary">#F2F2F2</Color>
            <Color x:Key="ColorText">#F4F4F4</Color>
            <Color x:Key="ColorError">#B04A4A</Color>

            <SolidColorBrush x:Key="BrushBackground" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="BrushSurface" Color="#141414"/>
            <SolidColorBrush x:Key="BrushPrimary" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="BrushText" Color="#F4F4F4"/>
            <SolidColorBrush x:Key="BrushMuted" Color="#9D9D9D"/>
            <SolidColorBrush x:Key="BrushDivider" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="BrushError" Color="#B04A4A"/>
            
        </ResourceDictionary>
    </Application.Resources>
</Application>
